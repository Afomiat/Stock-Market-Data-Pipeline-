# Frontend Environment Variables Template
# Copy this file to .env or .env.local to configure your local setup,
# or set these environment variables on your deployment hosting provider (e.g., Render, Vercel, Netlify).

# The production HTTP/HTTPS URL of your Go backend API (e.g. https://your-backend.onrender.com)
# Leave blank during local development to use the built-in Vite dev proxy (which routes to localhost:8080 or your local server)
VITE_API_URL=

# The production WS/WSS URL of your Go backend WebSocket (e.g. wss://your-backend.onrender.com/ws)
# Leave blank during local development to use the built-in Vite dev proxy (which routes to your local WebSocket)
VITE_WS_URL=
